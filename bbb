#!/usr/bin/env python3

import oci
from oci.pagination import list_call_get_all_results

SERVICE_NAME = "compute"


def main():
    # Load OCI config from ~/.oci/config
    config = oci.config.from_file()

    tenancy_id = config["tenancy"]

    identity_client = oci.identity.IdentityClient(config)
    limits_client = oci.limits.LimitsClient(config)

    # Get availability domains
    ads = identity_client.list_availability_domains(
        compartment_id=tenancy_id
    ).data

    print(f"Tenancy: {tenancy_id}")
    print(f"Service: {SERVICE_NAME}")
    print(f"Availability Domains: {[ad.name for ad in ads]}")
    print()

    # Get all limit values for the root compartment
    limits = list_call_get_all_results(
        limits_client.list_limit_values,
        compartment_id=tenancy_id,
        service_name=SERVICE_NAME
    ).data

    if not limits:
        print("No limits found.")
        return

    for limit in limits:
        print("=" * 100)
        print(f"Limit Name : {limit.name}")
        print(f"Limit Value: {limit.value}")

        for ad in ads:
            try:
                availability = limits_client.get_resource_availability(
                    service_name=SERVICE_NAME,
                    limit_name=limit.name,
                    compartment_id=tenancy_id,
                    availability_domain=ad.name
                ).data

                available = availability.available
                used = None

                if (
                    limit.value is not None
                    and available is not None
                    and isinstance(limit.value, (int, float))
                ):
                    used = limit.value - available

                print(f"\n  AD: {ad.name}")
                print(f"    Available: {available}")

                if used is not None:
                    print(f"    Used     : {used}")

            except oci.exceptions.ServiceError as e:
                print(f"\n  AD: {ad.name}")
                print(f"    Error: {e.message}")

    print("\nDone")


if __name__ == "__main__":
    main()import oci

